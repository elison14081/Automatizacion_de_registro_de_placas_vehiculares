
{
  "name": "Enviar QR WhatsApp - Sistema Parkeo",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "qr_whatsapp",
        "responseMode": "responseNode",
        "options": {}
      },
      "name": "Webhook",
      "type": "n8n-nodes-base.webhook",
      "position": [250, 300]
    },
    {
      "parameters": {
        "respondWith": "json",
        "responseBody": "={{ { \"success\": true, \"message\": \"QR enviado\" } }}"
      },
      "name": "Respond to Webhook",
      "type": "n8n-nodes-base.respondToWebhook",
      "position": [850, 300]
    },
    {
      "parameters": {
        "resource": "message",
        "operation": "sendMedia",
        "chatId": "={{ $json.numero }}@c.us",
        "mediaType": "image",
        "binaryData": false,
        "mediaUrl": "=data:image/png;base64,{{ $json.qr_base64 }}",
        "caption": "={{ $json.mensaje }}"
      },
      "name": "WhatsApp Business",
      "type": "n8n-nodes-base.whatsApp",
      "position": [550, 300]
    }
  ],
  "connections": {
    "Webhook": {
      "main": [[{"node": "WhatsApp Business", "type": "main", "index": 0}]]
    },
    "WhatsApp Business": {
      "main": [[{"node": "Respond to Webhook", "type": "main", "index": 0}]]
    }
  }
}